      "after": {
        "in": "query",
        "name": "after",
        "description": "Minimum creation time (in ISO 8601 format). You can specify just the date part as a shorthand for the start of\nthe day.\n",
        "schema": {
          "type": "string",
          "example": "2020-10-28T18:17:18Z"
        },
        "required": false
      },
      "before": {
        "in": "query",
        "name": "before",
        "description": "Maximum creation time (in ISO 8601 format). You can specify just the date part as a shorthand for the end of the\nday.\n",
        "schema": {
          "type": "string",
          "example": "2020-10-28"
        },
        "required": false
      },
      "query": {
        "in": "query",
        "name": "query",
        "description": "Filter results with a simple search query.",
        "schema": {
          "type": "string",
          "example": "foo bar"
        },
        "required": false
      }
