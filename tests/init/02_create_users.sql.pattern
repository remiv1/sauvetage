---------------------------------------------------------
-- BASE USERS
---------------------------------------------------------
\c ${POSTGRES_DB_USERS}

-- Migrateur
GRANT CONNECT ON DATABASE ${POSTGRES_DB_USERS} TO ${POSTGRES_USER_MIGR};
GRANT USAGE, CREATE ON SCHEMA migr_users TO ${POSTGRES_USER_MIGR};

-- Secure (RW)
GRANT CONNECT ON DATABASE ${POSTGRES_DB_USERS} TO ${POSTGRES_USER_SECURE};
GRANT USAGE ON SCHEMA auth_schema TO ${POSTGRES_USER_SECURE};
GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA auth_schema TO ${POSTGRES_USER_SECURE};

ALTER DEFAULT PRIVILEGES FOR ROLE ${POSTGRES_USER_MIGR} IN SCHEMA auth_schema
GRANT SELECT, INSERT, UPDATE, DELETE ON TABLES TO ${POSTGRES_USER_SECURE};
ALTER DEFAULT PRIVILEGES FOR ROLE ${POSTGRES_USER_MIGR} IN SCHEMA auth_schema
GRANT USAGE, SELECT ON SEQUENCES TO ${POSTGRES_USER_SECURE};

-- Définir le search_path par défaut pour les rôles utilisateurs sur la base users
ALTER ROLE ${POSTGRES_USER_SECURE} SET search_path TO auth_schema,public;
ALTER ROLE ${POSTGRES_USER_APP} SET search_path TO auth_schema,public;

-- App (RO)
GRANT CONNECT ON DATABASE ${POSTGRES_DB_USERS} TO ${POSTGRES_USER_APP};
GRANT USAGE ON SCHEMA auth_schema TO ${POSTGRES_USER_APP};
GRANT SELECT ON ALL TABLES IN SCHEMA auth_schema TO ${POSTGRES_USER_APP};

ALTER DEFAULT PRIVILEGES FOR ROLE ${POSTGRES_USER_MIGR} IN SCHEMA auth_schema
GRANT SELECT ON TABLES TO ${POSTGRES_USER_APP};
ALTER DEFAULT PRIVILEGES FOR ROLE ${POSTGRES_USER_MIGR} IN SCHEMA auth_schema
GRANT USAGE, SELECT ON SEQUENCES TO ${POSTGRES_USER_APP};

-- Migrateur (RW sur auth_schema)
GRANT USAGE, CREATE ON SCHEMA auth_schema TO ${POSTGRES_USER_MIGR};
GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA auth_schema TO ${POSTGRES_USER_MIGR};
GRANT USAGE, SELECT, UPDATE ON ALL SEQUENCES IN SCHEMA auth_schema TO ${POSTGRES_USER_MIGR};

---------------------------------------------------------
-- BASE MAIN
---------------------------------------------------------
\c ${POSTGRES_DB_MAIN}

-- Donner la propriété du schéma de migration
ALTER SCHEMA migr_main OWNER TO ${POSTGRES_USER_MIGR};

-- Migrateur (RW sur app_schema)
GRANT CONNECT ON DATABASE ${POSTGRES_DB_MAIN} TO ${POSTGRES_USER_MIGR};
GRANT USAGE, CREATE ON SCHEMA migr_main TO ${POSTGRES_USER_MIGR};
GRANT USAGE, CREATE ON SCHEMA app_schema TO ${POSTGRES_USER_MIGR};
GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA app_schema TO ${POSTGRES_USER_MIGR};
GRANT USAGE, SELECT, UPDATE ON ALL SEQUENCES IN SCHEMA app_schema TO ${POSTGRES_USER_MIGR};

-- App (RW)
GRANT CONNECT ON DATABASE ${POSTGRES_DB_MAIN} TO ${POSTGRES_USER_APP};
GRANT USAGE ON SCHEMA app_schema TO ${POSTGRES_USER_APP};
GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA app_schema TO ${POSTGRES_USER_APP};

ALTER DEFAULT PRIVILEGES FOR ROLE ${POSTGRES_USER_MIGR} IN SCHEMA app_schema
GRANT SELECT, INSERT, UPDATE, DELETE ON TABLES TO ${POSTGRES_USER_APP};
ALTER DEFAULT PRIVILEGES FOR ROLE ${POSTGRES_USER_MIGR} IN SCHEMA app_schema
GRANT USAGE, SELECT, UPDATE ON SEQUENCES TO ${POSTGRES_USER_APP};

-- Définir le search_path par défaut pour le rôle app sur la base main
ALTER ROLE ${POSTGRES_USER_APP} SET search_path TO app_schema,public;